@import "tailwindcss";

/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* SCROLL */
html {
  scroll-behavior: smooth;
}

/* FUNDO PROFISSIONAL */
body {
  background: radial-gradient(circle at top, #020617, #020617 40%, #0f172a);
  color: white;
}

/* EFEITO GLOW */
.glow {
  box-shadow: 0 0 40px rgba(59,130,246,0.4);
}
